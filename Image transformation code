def demo_homogeneous_coordinates():
    print("\n--- Demo: Homogeneous Coordinates (Translation) ---")
    # Create a simple image (square)
    image = np.zeros((10, 10))
    image[3:7, 3:7] = 1   # white square in the middle

    # Translation values
    tx = 3  # shift in x-direction
    ty = 2  # shift in y-direction

    # Homogeneous translation matrix
    T = np.array([
        [1, 0, tx],
        [0, 1, ty],
        [0, 0, 1]
    ])

    # Get coordinates of white pixels
    points = np.argwhere(image == 1)

    # Convert to homogeneous coordinates
    homogeneous_points = np.column_stack((points, np.ones(len(points))))

    # Apply translation
    translated_points = (T @ homogeneous_points.T).T

    # Create new translated image
    translated_image = np.zeros_like(image)
    for p in translated_points:
        x, y = int(p[0]), int(p[1])
        if 0 <= x < 10 and 0 <= y < 10:
            translated_image[x, y] = 1

    # Plot
    plt.figure(figsize=(8, 4))
    plt.subplot(1, 2, 1)
    plt.imshow(image, cmap='gray')
    plt.title("Original (10x10 Grid)")
    plt.axis('off')

    plt.subplot(1, 2, 2)
    plt.imshow(translated_image, cmap='gray')
    plt.title(f"Homogeneous Translation (tx={tx}, ty={ty})")
    plt.axis('off')
    plt.show()

def demo_linear_combination_points():
    print("\n--- Demo: Linear Combination (Scatter Plot) ---")
    # Original points
    points = np.array([[1, 1], [2, 1], [2, 2], [1, 2]])

    # Scaling matrix
    scaling_matrix = np.array([[2, 0], [0, 2]])

    # Rotation matrix (45 degrees)
    theta = np.pi / 4
    rotation_matrix = np.array([
        [np.cos(theta), -np.sin(theta)],
        [np.sin(theta),  np.cos(theta)]
    ])

    # Apply linear transformations
    scaled_points = points @ scaling_matrix.T
    rotated_points = points @ rotation_matrix.T

    # Plotting
    plt.figure()
    plt.scatter(points[:, 0], points[:, 1], label="Original Points")
    plt.scatter(scaled_points[:, 0], scaled_points[:, 1], label="Scaled Points")
    plt.scatter(rotated_points[:, 0], rotated_points[:, 1], label="Rotated Points")
    plt.legend()
    plt.grid()
    plt.title("Linear Combination of Points")
    plt.show()

def demo_affine_scipy():
    print("\n--- Demo: Affine Transform (SciPy) ---")
    # Create a larger image
    size = 200
    image = np.zeros((size, size))
    square_start, square_end = 80, 120
    image[square_start:square_end, square_start:square_end] = 1

    # Affine transformation parameters
    scale_x = 1.2
    scale_y = 1.2
    theta = np.pi / 6  # 30 degrees
    tx = 20            
    ty = 10            

    # Affine matrix for scipy (2x2 part only)
    rotation_scale = np.array([
        [scale_x * np.cos(theta), -np.sin(theta)],
        [np.sin(theta), scale_y * np.cos(theta)]
    ])

    offset = [-ty, -tx]  # scipy uses (row, col)

    # Apply affine transformation
    transformed_image = affine_transform(
        image, rotation_scale, offset=offset, order=3, mode='constant', cval=0.0
    )

    # Plot
    plt.figure(figsize=(10, 5))
    plt.subplot(1, 2, 1)
    plt.imshow(image, cmap='gray')
    plt.title("Original Generated Image")
    plt.axis('off')

    plt.subplot(1, 2, 2)
    plt.imshow(transformed_image, cmap='gray')
    plt.title("SciPy Affine Result")
    plt.axis('off')
    plt.show()

