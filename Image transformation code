def main():
    print("Please select an image to start .")
    
    img_path = select_image()
    if not img_path:
        print("No file selected. Exiting program.")
        return

    img = cv2.imread(img_path)
    if img is None:
        print(f"Error: Could not read image from {img_path}")
        return
    
    print(f"Successfully loaded: {img_path}")

    while True:
        print("\n" + "="*50)
        print("     IMAGE TRANSFORMATION & MATH DEMOS     ")
        print("="*50)
        print("--- Applied to YOUR Image ---")
        print("1. Scaling")
        print("2. Translation")
        print("3. Rotation")
        print("4. Shearing")
        print("5. Select New Image")
        print("6.  Homogeneous Coordinates (Grid Translation)")
        print("7.  Linear Combination (Points Plot)")
        print("8.  Affine Transform (SciPy Square)")
        print("-------------------------------------------")
        print("0. Exit")
        print("="*50)
        
        choice = input("Select an operation (0-8): ")

        if choice == '1':
            apply_scaling(img)
        elif choice == '2':
            apply_translation(img)
        elif choice == '3':
            apply_rotation(img)
        elif choice == '4':
            apply_shearing(img)
        elif choice == '5':
            new_path = select_image()
            if new_path:
                img = cv2.imread(new_path)
                print(f"New image loaded: {new_path}")
            else:
                print("Selection canceled.")
        
        # --- New Options ---
        elif choice == '6':
            demo_homogeneous_coordinates()
        elif choice == '7':
            demo_linear_combination_points()
        elif choice == '8':
            demo_affine_scipy()
            
        elif choice == '0':
            print("Exiting program. Goodbye!")
            break
        else:
            print("Invalid choice, please try again.")

if __name__ == "__main__":
    main()
