import cv2
import numpy as np
import matplotlib.pyplot as plt
import tkinter as tk
from tkinter import filedialog
from scipy.ndimage import affine_transform  # مكتبة SciPy المطلوبة للكود الثالث

# ---------------------------------------------------------
# Function to select an image from the computer
# ---------------------------------------------------------
def select_image():
    print("Opening file dialog...")
    root = tk.Tk()
    root.withdraw() 
    file_path = filedialog.askopenfilename(
        title="Select an Image",
        filetypes=[("Image files", "*.jpg *.jpeg *.png *.bmp *.tiff")]
    )
    return file_path

# ---------------------------------------------------------
# Helper function to display results using Matplotlib
# ---------------------------------------------------------
def show_result(title, original, transformed):
    plt.figure(figsize=(10, 5))
    
    # Show Original Image
    plt.subplot(1, 2, 1)
    if len(original.shape) == 3:
        plt.imshow(cv2.cvtColor(original, cv2.COLOR_BGR2RGB))
    else:
        plt.imshow(original, cmap='gray')
    plt.title("Original Image")
    plt.axis('off')

    # Show Transformed Image
    plt.subplot(1, 2, 2)
    if len(transformed.shape) == 3:
        plt.imshow(cv2.cvtColor(transformed, cv2.COLOR_BGR2RGB))
    else:
        plt.imshow(transformed, cmap='gray')
    plt.title(title)
    plt.axis('off')

    plt.show()

# ---------------------------------------------------------
# Standard OpenCV Transformations (Applied to your Image)
# ---------------------------------------------------------

def apply_scaling(img):
    print("\n--- Scaling Mode ---")
    try:
        fx = float(input("Enter scale factor for X (e.g., 0.5, 2.0): "))
        fy = float(input("Enter scale factor for Y (e.g., 0.5, 2.0): "))
        res = cv2.resize(img, None, fx=fx, fy=fy, interpolation=cv2.INTER_LINEAR)
        show_result(f"Scaled (X:{fx}, Y:{fy})", img, res)
    except ValueError:
        print("Invalid input! Please enter numeric values.")

def apply_translation(img):
    print("\n--- Translation Mode ---")
    rows, cols = img.shape[:2]
    try:
        tx = float(input("Enter shift in X (pixels): "))
        ty = float(input("Enter shift in Y (pixels): "))
        M = np.float32([[1, 0, tx], [0, 1, ty]])
        res = cv2.warpAffine(img, M, (cols, rows))
        show_result(f"Translated (X:{tx}, Y:{ty})", img, res)
    except ValueError:
        print("Invalid input! Please enter numeric values.")

def apply_rotation(img):
    print("\n--- Rotation Mode ---")
    rows, cols = img.shape[:2]
    try:
        angle = float(input("Enter rotation angle (degrees): "))
        center = (cols // 2, rows // 2)
        M = cv2.getRotationMatrix2D(center, angle, 1.0)
        res = cv2.warpAffine(img, M, (cols, rows))
        show_result(f"Rotated ({angle} deg)", img, res)
    except ValueError:
        print("Invalid input! Please enter numeric values.")

def apply_shearing(img):
    print("\n--- Shearing Mode ---")
    rows, cols = img.shape[:2]
    try:
        shx = float(input("Enter shear factor for X (e.g., 0.2): "))
        M = np.float32([[1, shx, 0], [0, 1, 0]])
        res = cv2.warpAffine(img, M, (int(cols*1.5), rows))
        show_result(f"Sheared (Factor: {shx})", img, res)
    except ValueError:
        print("Invalid input! Please enter numeric values.")

